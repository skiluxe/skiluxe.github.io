<!doctype html>
<html lang="{{ lang }}" dir="{{ dir or 'ltr' }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} · {{ site.brand }}{% else %}{{ i18n[lang].meta.title }}{% endif %}</title>
  <meta name="description" content="{{ description or i18n[lang].meta.description }}">
  <meta property="og:title" content="{{ title or i18n[lang].meta.title }}">
  <meta property="og:description" content="{{ description or i18n[lang].meta.description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://{{ site.domain }}{{ page.url }}">
  <meta property="og:image" content="https://{{ site.domain }}/assets/img/og/default.svg">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
  <link rel="alternate" type="application/atom+xml" title="iCal" href="/assets/feeds/all.ics">
  {% for l in site.langs %}
  <link rel="alternate" hreflang="{{ l.code }}" href="https://{{ site.domain }}/{{ l.code }}{{ page.url | replace('/' + lang + '/', '/') }}">
  {% endfor %}
  <link rel="alternate" hreflang="x-default" href="https://{{ site.domain }}/">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,500&family=Inter:wght@300;400;500;600;700&family=Noto+Sans+Georgian:wght@400;500;600;700&family=Heebo:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/main.css">
  {% if dir == 'rtl' %}<link rel="stylesheet" href="/assets/css/rtl.css">{% endif %}
  {% if extraCss %}<link rel="stylesheet" href="{{ extraCss }}">{% endif %}
  <script>
    window.SKILUXE_CONFIG = { apiBase: "{{ site.apiBase }}", lang: "{{ lang }}", domain: "{{ site.domain }}" };
    window.SKILUXE_I18N = {
      select_dates: {{ i18n[lang].booking.select_dates | dump | safe }},
      min_stay: {{ i18n[lang].booking.min_stay | dump | safe }},
      max_guests: {{ i18n[lang].booking.max_guests | dump | safe }},
      success_text: {{ i18n[lang].booking.success_text | dump | safe }},
      error_generic: {{ i18n[lang].booking.error_generic | dump | safe }},
      rate_limited: {{ i18n[lang].booking.rate_limited | default(i18n[lang].booking.error_generic) | dump | safe }},
      unavailable: {{ i18n[lang].booking.error_unavailable | dump | safe }}
    };
  </script>
</head>
<body class="lang-{{ lang }}">
  <a class="skip-link" href="#main">{{ i18n[lang].nav.home }}</a>

  {% include "partials/header.njk" %}

  <main id="main">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script type="module" src="/assets/js/lang.js"></script>
  {% if extraJs %}<script type="module" src="{{ extraJs }}"></script>{% endif %}
</body>
</html>
