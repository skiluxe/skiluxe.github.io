<section class="page-hero">
  <div class="container">
    <p class="eyebrow">{{ i18n[lang].nav.contact }}</p>
    <h1 class="display">{{ i18n[lang].contact.title }}</h1>
    <p class="lead">{{ i18n[lang].contact.subtitle }}</p>
  </div>
</section>

<section class="container section contact__grid">
  <div class="contact__cards">
    <a class="contact-card" href="https://wa.me/{{ site.whatsapp | replace('+', '') | replace(' ', '') }}">
      <div class="contact-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="M12 2 a10 10 0 0 0 -8.5 15.2 L2 22 l4.9 -1.4 A10 10 0 1 0 12 2 Z M8.4 7.5 c0.3 0 0.5 0 0.7 0 0.2 0 0.5 0 0.7 0.5 0.3 0.6 0.9 2 1 2.2 0.1 0.2 0.1 0.4 0 0.6 -0.1 0.2 -0.2 0.3 -0.3 0.5 -0.2 0.2 -0.4 0.4 -0.5 0.6 -0.2 0.2 -0.4 0.4 -0.2 0.7 0.2 0.4 1 1.5 2.1 2.4 1.4 1.2 2.5 1.5 2.9 1.7 0.4 0.2 0.6 0.1 0.8 -0.1 0.2 -0.2 0.9 -1 1.1 -1.3 0.2 -0.3 0.5 -0.2 0.7 -0.1 0.3 0.1 1.7 0.8 2 1 0.3 0.1 0.5 0.2 0.6 0.3 0.1 0.2 0.1 1.1 -0.3 2.1 -0.4 1 -2.2 1.9 -3 2 -0.8 0.1 -1.9 0.2 -3 -0.3 -3 -1.2 -5.3 -3.7 -6.5 -5.4 -1.2 -1.6 -1.9 -3.2 -1.9 -4.6 0 -1.4 0.7 -2.1 1 -2.4 0.3 -0.3 0.6 -0.3 0.8 -0.3 z" fill="currentColor"/></svg>
      </div>
      <div>
        <h3>{{ i18n[lang].contact.whatsapp }}</h3>
        <p>{{ site.whatsappDisplay }}</p>
      </div>
    </a>
    <a class="contact-card" href="mailto:{{ site.email }}">
      <div class="contact-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M4 7 L12 13 L20 7" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
      </div>
      <div>
        <h3>{{ i18n[lang].contact.email }}</h3>
        <p>{{ site.email }}</p>
      </div>
    </a>
    <a class="contact-card" href="{{ site.instagramUrl }}" rel="noopener noreferrer">
      <div class="contact-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
      </div>
      <div>
        <h3>{{ i18n[lang].contact.instagram }}</h3>
        <p>@{{ site.instagram }}</p>
      </div>
    </a>
    <a class="contact-card" href="{{ site.telegramUrl }}" rel="noopener noreferrer">
      <div class="contact-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="M21.5 3.5 L2.5 10.5 c-0.8 0.3 -0.8 0.8 -0.1 1 l4.8 1.5 1.8 5.6 c0.2 0.6 0.6 0.6 0.9 0.1 l2.6 -3.2 5.1 3.8 c0.5 0.4 0.9 0.2 1 -0.4 l3.8 -13.5 c0.2 -0.7 -0.3 -1 -0.9 -0.8 z M8.5 13.5 l9.5 -6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
      </div>
      <div>
        <h3>{{ i18n[lang].contact.telegram }}</h3>
        <p>{{ i18n[lang].contact.telegram_hint }}</p>
      </div>
    </a>
  </div>

  <div class="contact__notes">
    <div>
      <h3>{{ i18n[lang].contact.directions_title }}</h3>
      <p>{{ i18n[lang].contact.directions_text }}</p>
    </div>
    <div>
      <h3>{{ i18n[lang].contact.checkin_title }}</h3>
      <p>{{ i18n[lang].contact.checkin_text }}</p>
    </div>
  </div>
</section>
