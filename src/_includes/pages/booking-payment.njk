<section class="page-hero">
  <div class="container">
    <p class="eyebrow">{{ i18n[lang].booking.title }}</p>
    <h1 class="display">{{ i18n[lang].payment.page_title }}</h1>
    <p class="lead">{{ i18n[lang].payment.page_subtitle }}</p>
  </div>
</section>

<section class="container section">
  <div class="booking-payment" id="booking-payment">
    <div class="booking-payment__loading">
      <p>{{ i18n[lang].payment.checking }}</p>
    </div>
    <div class="booking-payment__success" hidden>
      <h2>{{ i18n[lang].payment.success_title }}</h2>
      <p class="booking-payment__text"></p>
      <a class="btn btn--primary" href="/{{ lang }}/apartments/">{{ i18n[lang].payment.back_apartments }}</a>
    </div>
    <div class="booking-payment__pending" hidden>
      <h2>{{ i18n[lang].payment.pending_title }}</h2>
      <p class="booking-payment__text"></p>
      <a class="btn btn--ghost" href="https://wa.me/{{ site.whatsapp | replace('+', '') | replace(' ', '') }}">{{ i18n[lang].contact.whatsapp }}</a>
    </div>
    <div class="booking-payment__failed" hidden>
      <h2>{{ i18n[lang].payment.failed_title }}</h2>
      <p class="booking-payment__text"></p>
      <a class="btn btn--primary" href="/{{ lang }}/apartments/">{{ i18n[lang].payment.try_again }}</a>
    </div>
    <div class="booking-payment__error" role="alert" hidden></div>
  </div>
</section>

<script>
  window.SKILUXE_PAYMENT_I18N = {
    success_text: {{ i18n[lang].payment.success_text | dump | safe }},
    pending_text: {{ i18n[lang].payment.pending_text | dump | safe }},
    failed_text: {{ i18n[lang].payment.failed_text | dump | safe }},
    error_generic: {{ i18n[lang].booking.error_generic | dump | safe }}
  };
</script>
