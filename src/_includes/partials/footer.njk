<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <div class="site-brand site-brand--footer">
        {% include "partials/brand-mark.njk" %}
        <span class="site-brand__text">
          <span class="site-brand__name">{{ site.brandShort }}</span>
          <span class="site-brand__tag">New Gudauri</span>
        </span>
      </div>
      <p class="site-footer__tag">{{ i18n[lang].footer.built }}</p>
    </div>

    <div class="site-footer__col">
      <h4>{{ i18n[lang].footer.links }}</h4>
      <ul>
        <li><a href="/{{ lang }}/">{{ i18n[lang].nav.home }}</a></li>
        <li><a href="/{{ lang }}/apartments/">{{ i18n[lang].nav.apartments }}</a></li>
        <li><a href="/{{ lang }}/about/">{{ i18n[lang].nav.about }}</a></li>
        <li><a href="/{{ lang }}/contact/">{{ i18n[lang].nav.contact }}</a></li>
      </ul>
    </div>

    <div class="site-footer__col">
      <h4>{{ i18n[lang].footer.contact }}</h4>
      <ul>
        <li><a href="https://wa.me/{{ site.whatsapp | replace('+', '') | replace(' ', '') }}">{{ site.whatsappDisplay }}</a></li>
        <li><a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
        <li><a href="{{ site.instagramUrl }}" rel="noopener noreferrer">@{{ site.instagram }}</a></li>
        <li><a href="{{ site.telegramUrl }}" rel="noopener noreferrer">@{{ site.telegram }}</a></li>
      </ul>
    </div>
  </div>

  <div class="container site-footer__base">
    <small>{% tx "footer.legal", { year: page.date | year } %}</small>
    <div class="site-footer__langs">
      {% for l in site.langs %}<a href="/{{ l.code }}/" lang="{{ l.code }}">{{ l.label }}</a>{% if not loop.last %} · {% endif %}{% endfor %}
    </div>
  </div>
</footer>
