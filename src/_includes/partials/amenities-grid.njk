<section class="amenities">
  <h2 class="section-title">{{ i18n[lang].amenities.title }}</h2>
  <ul class="amenities__grid">
    {% for key in apartment.amenities %}
    <li class="amenities__item">
      <svg class="amenities__icon" viewBox="0 0 24 24" aria-hidden="true">
        {% if key == "wifi" %}<path d="M2 9 a14 14 0 0 1 20 0 M5 12.5 a9 9 0 0 1 14 0 M8 16 a4 4 0 0 1 8 0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="20" r="1.2" fill="currentColor"/>
        {% elif key == "kitchen" %}<rect x="3" y="4" width="18" height="16" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M3 10 H21 M9 4 V10 M15 4 V10" fill="none" stroke="currentColor" stroke-width="1.5"/>
        {% elif key == "balcony" %}<path d="M3 13 H21 M5 13 V21 M19 13 V21 M9 13 V21 M15 13 V21 M3 10 H21 M5 10 V13 M19 10 V13 M5 3 L8 8 M19 3 L16 8 M8 8 H16" fill="none" stroke="currentColor" stroke-width="1.5"/>
        {% elif key == "heating" %}<path d="M7 21 V9 a2 2 0 0 1 4 0 V21 M13 21 V9 a2 2 0 0 1 4 0 V21 M9 6 c0 -2 2 -2 2 -4 M15 6 c0 -2 2 -2 2 -4" fill="none" stroke="currentColor" stroke-width="1.5"/>
        {% elif key == "tv" %}<rect x="2" y="5" width="20" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M8 21 H16 M12 18 V21" fill="none" stroke="currentColor" stroke-width="1.5"/>
        {% elif key == "washer" %}<rect x="4" y="3" width="16" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="14" r="5" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="16" cy="6" r="0.8" fill="currentColor"/>
        {% elif key == "ski_storage" %}<path d="M6 21 L11 3 M13 3 L18 21 M7 19 H17 M9 11 H15" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        {% elif key == "parking" %}<rect x="3" y="3" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M9 17 V7 H13 a3 3 0 0 1 0 6 H9" fill="none" stroke="currentColor" stroke-width="1.5"/>
        {% elif key == "mountain_view" %}<path d="M2 19 L9 9 L13 14 L17 8 L22 19 Z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="18" cy="6" r="1.8" fill="none" stroke="currentColor" stroke-width="1.5"/>
        {% elif key == "coffee_machine" %}<path d="M5 8 H17 V14 a4 4 0 0 1 -4 4 H9 a4 4 0 0 1 -4 -4 V8 Z M17 10 h2 a2 2 0 0 1 0 4 h-2 M9 5 c0 -1 -1 -1 -1 -2 M13 5 c0 -1 -1 -1 -1 -2" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        {% elif key == "linens" %}<path d="M4 6 H20 V18 H4 Z M4 10 H20 M8 6 V18 M16 6 V18" fill="none" stroke="currentColor" stroke-width="1.5"/>
        {% elif key == "towels" %}<path d="M6 3 H18 V21 H6 Z M6 7 H18 M6 17 H18" fill="none" stroke="currentColor" stroke-width="1.5"/>
        {% elif key == "sofa_bed" %}<path d="M2 16 V11 a3 3 0 0 1 3 -3 H19 a3 3 0 0 1 3 3 V16 M2 16 H22 M2 16 V20 M22 16 V20 M5 11 H19" fill="none" stroke="currentColor" stroke-width="1.5"/>
        {% else %}<circle cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="1.5"/>
        {% endif %}
      </svg>
      <span>{{ i18n[lang].amenity[key] }}</span>
    </li>
    {% endfor %}
  </ul>
</section>
