<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-brand" href="/{{ lang }}/" aria-label="{{ site.brand }}">
      {% include "partials/brand-mark.njk" %}
      <span class="site-brand__text">
        <span class="site-brand__name">{{ site.brandShort }}</span>
        <span class="site-brand__tag">New Gudauri</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a href="/{{ lang }}/">{{ i18n[lang].nav.home }}</a>
      <a href="/{{ lang }}/apartments/">{{ i18n[lang].nav.apartments }}</a>
      <a href="/{{ lang }}/about/">{{ i18n[lang].nav.about }}</a>
      <a href="/{{ lang }}/live-camera/">{{ i18n[lang].nav.live_camera }}</a>
      <a href="/{{ lang }}/contact/">{{ i18n[lang].nav.contact }}</a>
    </nav>

    <div class="site-actions">
      {% include "partials/lang-switcher.njk" %}
      <a class="btn btn--ghost" href="/{{ lang }}/apartments/">{{ i18n[lang].nav.book }}</a>
    </div>

    <button class="nav-toggle" type="button" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
